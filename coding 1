import numpy as np
from sklearn.linear_model import LinearRegression
X = np.array([
    [4, 64, 4000],
    [6, 128, 4500],
    [8, 128, 5000],
    [12, 256, 6000],
    [3, 32, 3500]
])
y = np.array([15, 20, 25, 35, 10])

model = LinearRegression()
model.fit(X, y)

new_mobile = np.array([[8, 256, 5000]])

price = model.predict(new_mobile)

print("Predicted Mobile Price:", price)

